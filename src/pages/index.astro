<script>
  function isValidEmail(value: string): boolean {
    return /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(value);
  }

  function setError(input: HTMLInputElement | HTMLTextAreaElement, errorEl: HTMLElement, show: boolean) {
    if (show) {
      errorEl.classList.remove('hidden');
      input.classList.add('border-red-400/60');
      input.classList.remove('border-white/10');
    } else {
      errorEl.classList.add('hidden');
      input.classList.remove('border-red-400/60');
      input.classList.add('border-white/10');
    }
  }

  const nameInput    = document.getElementById('contact-name')    as HTMLInputElement;
  const emailInput   = document.getElementById('contact-email')   as HTMLInputElement;
  const messageInput = document.getElementById('contact-message') as HTMLTextAreaElement;
  const nameError    = document.getElementById('name-error')      as HTMLElement;
  const emailError   = document.getElementById('email-error')     as HTMLElement;
  const messageError = document.getElementById('message-error')   as HTMLElement;
  const form         = document.getElementById('contact-form')    as HTMLElement;
  const success      = document.getElementById('contact-success') as HTMLElement;

  document.getElementById('contact-btn')!.addEventListener('click', () => {
    const nameOk    = nameInput.value.trim().length > 0;
    const emailOk   = isValidEmail(emailInput.value.trim());
    const messageOk = messageInput.value.trim().length > 0;

    setError(nameInput,    nameError,    !nameOk);
    setError(emailInput,   emailError,   !emailOk);
    setError(messageInput, messageError, !messageOk);

    if (!nameOk || !emailOk || !messageOk) return;

    form.classList.add('hidden');
    success.classList.remove('hidden');
    success.classList.add('flex');
  });

  [nameInput, emailInput, messageInput].forEach((el, i) => {
    const errEl = [nameError, emailError, messageError][i];
    el.addEventListener('input', () => setError(el, errEl, false));
  });
</script>

