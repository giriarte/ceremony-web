---
import Layout from '../layouts/Layout.astro';

const liveProducts = [
  {
    name: 'F1 Cronos',
    slug: 'f1cronos',
    tagline: 'Live & historical Formula 1 analytics',
    description:
      'Dive deep into race data, lap times, driver performance, and historical stats from every Formula 1 season — all in one place.',
    icon: '🏎️',
    url: 'https://f1cronos.com',
    videoId: 'YtN7-km8IRg',
    accent: 'blue',
  },
  {
    name: 'Universo Cromos',
    slug: 'universo-cromos',
    tagline: 'Marketplace for collectible items',
    description:
      'A curated marketplace where collectors discover, buy, and sell their favourite stickers and collectible cards — managed and trusted by our team.',
    icon: '🃏',
    url: 'https://www.cromos-universo.com',
    videoId: 'Zm8O60NSD8I',
    accent: 'pink',
  },
];

const products = [
  {
    name: 'Trade On',
    slug: 'tradeon',
    tagline: 'Configurable trading strategy alerts',
    description:
      'Build and configure custom trading strategies, set your own conditions, and receive real-time alerts when the market moves your way.',
    icon: '📈',
    accent: 'pink',
  },
  {
    name: 'Petbook',
    slug: 'petbook',
    tagline: 'Modern pet adoption, simplified',
    description:
      'A friendly platform connecting animals in need with loving homes. Browse, filter, and find your perfect companion.',
    icon: '🐾',
    accent: 'blue',
  },
];

const stepIcons = [
  // 0 — Discovery: magnifying glass over bar chart (blue)
  `<svg viewBox="0 0 160 160" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="80" cy="80" r="70" fill="rgba(59,130,246,.08)"/><rect x="36" y="48" width="60" height="76" rx="8" fill="#080f1f" stroke="rgba(59,130,246,.28)" stroke-width="1.5"/><rect x="48" y="63" width="36" height="2.5" rx="1.2" fill="rgba(96,165,250,.35)"/><rect x="48" y="70" width="24" height="2" rx="1" fill="rgba(96,165,250,.2)"/><rect x="48" y="99" width="10" height="16" rx="2" fill="rgba(59,130,246,.4)"/><rect x="63" y="90" width="10" height="25" rx="2" fill="rgba(59,130,246,.62)"/><rect x="78" y="81" width="10" height="34" rx="2" fill="#60a5fa" opacity=".82"/><circle cx="104" cy="57" r="24" fill="#060c1a" stroke="#60a5fa" stroke-width="2"/><circle cx="104" cy="57" r="15" fill="rgba(59,130,246,.07)" stroke="rgba(96,165,250,.22)" stroke-width="1"/><circle cx="97" cy="50" r="5" fill="rgba(255,255,255,.08)"/><line x1="121" y1="74" x2="133" y2="86" stroke="#60a5fa" stroke-width="3.5" stroke-linecap="round"/><circle cx="104" cy="57" r="30" stroke="rgba(96,165,250,.09)" stroke-width="7"/></svg>`,
  // 1 — Solution Design: connected node network (blue-pink)
  `<svg viewBox="0 0 160 160" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="80" cy="80" r="70" fill="rgba(99,102,241,.07)"/><circle cx="80" cy="80" r="22" stroke="rgba(96,165,250,.07)" stroke-width="1" stroke-dasharray="3 4"/><line x1="80" y1="44" x2="80" y2="67" stroke="rgba(96,165,250,.3)" stroke-width="1.5" stroke-dasharray="4 3"/><line x1="112" y1="54" x2="93" y2="71" stroke="rgba(244,114,182,.3)" stroke-width="1.5" stroke-dasharray="4 3"/><line x1="117" y1="109" x2="94" y2="89" stroke="rgba(236,72,153,.3)" stroke-width="1.5" stroke-dasharray="4 3"/><line x1="43" y1="107" x2="67" y2="89" stroke="rgba(129,140,248,.3)" stroke-width="1.5" stroke-dasharray="4 3"/><line x1="43" y1="53" x2="68" y2="71" stroke="rgba(96,165,250,.3)" stroke-width="1.5" stroke-dasharray="4 3"/><circle cx="80" cy="80" r="13" fill="#0a1220" stroke="#60a5fa" stroke-width="2"/><circle cx="80" cy="80" r="7" fill="rgba(59,130,246,.28)"/><circle cx="80" cy="80" r="3.5" fill="#60a5fa"/><circle cx="80" cy="36" r="9" fill="#0a1220" stroke="#93c5fd" stroke-width="1.5"/><circle cx="80" cy="36" r="4.5" fill="rgba(147,197,253,.38)"/><circle cx="119" cy="50" r="8" fill="#0a1220" stroke="#f472b6" stroke-width="1.5"/><circle cx="119" cy="50" r="4" fill="rgba(244,114,182,.38)"/><circle cx="123" cy="113" r="8" fill="#0a1220" stroke="#ec4899" stroke-width="1.5"/><circle cx="123" cy="113" r="4" fill="rgba(236,72,153,.33)"/><circle cx="37" cy="111" r="8" fill="#0a1220" stroke="#818cf8" stroke-width="1.5"/><circle cx="37" cy="111" r="4" fill="rgba(129,140,248,.38)"/><circle cx="37" cy="49" r="9" fill="#0a1220" stroke="#60a5fa" stroke-width="1.5"/><circle cx="37" cy="49" r="4.5" fill="rgba(59,130,246,.33)"/></svg>`,
  // 2 — Build: isometric stacked layers (pink)
  `<svg viewBox="0 0 160 160" fill="none" xmlns="http://www.w3.org/2000/svg"><circle cx="80" cy="80" r="70" fill="rgba(236,72,153,.07)"/><path d="M80 106 L114 88 L80 70 L46 88 Z" fill="#14082e" stroke="rgba(236,72,153,.22)" stroke-width="1"/><path d="M114 88 L114 106 L80 124 L80 106 Z" fill="#0e0521" stroke="rgba(236,72,153,.14)" stroke-width="1"/><path d="M46 88 L46 106 L80 124 L80 106 Z" fill="#120727" stroke="rgba(236,72,153,.14)" stroke-width="1"/><path d="M80 80 L108 65 L80 50 L52 65 Z" fill="#1a0a3a" stroke="rgba(244,114,182,.32)" stroke-width="1"/><path d="M108 65 L108 80 L80 95 L80 80 Z" fill="#120731" stroke="rgba(244,114,182,.18)" stroke-width="1"/><path d="M52 65 L52 80 L80 95 L80 80 Z" fill="#160935" stroke="rgba(244,114,182,.18)" stroke-width="1"/><path d="M80 55 L101 44 L80 33 L59 44 Z" fill="#210d48" stroke="#f472b6" stroke-width="1.5"/><path d="M101 44 L101 55 L80 66 L80 55 Z" fill="#18093e" stroke="rgba(244,114,182,.28)" stroke-width="1"/><path d="M59 44 L59 55 L80 66 L80 55 Z" fill="#1c0c44" stroke="rgba(244,114,182,.28)" stroke-width="1"/><circle cx="80" cy="38" r="5.5" fill="rgba(244,114,182,.45)"/><circle cx="80" cy="38" r="2.8" fill="#f472b6"/></svg>`,
  // 3 — Launch: rocket with flames (pink) — uses sc3b gradient for rocket body
  `<svg viewBox="0 0 160 160" fill="none" xmlns="http://www.w3.org/2000/svg"><defs><linearGradient id="sc3b" x1="0" y1="0" x2="0" y2="1"><stop offset="0%" stop-color="#fce7f3"/><stop offset="100%" stop-color="#ec4899"/></linearGradient></defs><circle cx="80" cy="80" r="70" fill="rgba(236,72,153,.08)"/><rect x="52" y="121" width="56" height="6" rx="3" fill="rgba(236,72,153,.18)" stroke="rgba(236,72,153,.28)" stroke-width="1"/><rect x="60" y="115" width="40" height="8" rx="2" fill="rgba(236,72,153,.1)" stroke="rgba(236,72,153,.18)" stroke-width="1"/><path d="M71 115 C73 126 77 132 80 134 C83 132 87 126 89 115" fill="rgba(251,146,60,.55)"/><path d="M74 115 C76 122 79 127 80 129 C81 127 84 122 86 115" fill="rgba(251,191,36,.75)"/><path d="M80 36 C70 50 66 72 66 93 L94 93 C94 72 90 50 80 36 Z" fill="url(#sc3b)"/><path d="M80 26 C75 31 72 38 70 45 L90 45 C88 38 85 31 80 26 Z" fill="#fdf2f8"/><circle cx="80" cy="70" r="9" fill="#07101f" stroke="#fce7f3" stroke-width="1.5"/><circle cx="80" cy="70" r="4.5" fill="rgba(252,231,243,.15)"/><circle cx="77" cy="67" r="2" fill="rgba(255,255,255,.2)"/><path d="M66 93 L55 114 L69 103 Z" fill="#be185d" opacity=".85"/><path d="M94 93 L105 114 L91 103 Z" fill="#be185d" opacity=".85"/><circle cx="44" cy="74" r="2.5" fill="rgba(244,114,182,.4)"/><circle cx="116" cy="70" r="2.5" fill="rgba(244,114,182,.4)"/><circle cx="36" cy="43" r="1.5" fill="rgba(255,255,255,.35)"/><circle cx="125" cy="37" r="2" fill="rgba(255,255,255,.28)"/></svg>`,
];

const processSteps = [
  {
    number: '1',
    category: 'Discovery',
    accent: 'blue',
    title: 'Understanding your business',
    tagline: 'We sit down with your team to collect information, map your workflows, and deeply understand the specific needs and pain points of your business.',
    description: 'Before writing a single line of code, we learn your business from the inside out. We interview stakeholders across every relevant department — operations, sales, management — to map how work actually flows today, where friction lives, and what outcomes matter most. This phase is about listening carefully, not prescribing solutions.',
    bullets: [
      'Stakeholder interviews across departments',
      'Current workflow and toolchain mapping',
      'Bottleneck and manual-process identification',
      'Success metric definition with your team',
      'Opportunity prioritization by business impact',
    ],
    duration: null,
    outcome: 'A clear problem statement and a ranked list of opportunities — agreed on by your team.',
    icon: stepIcons[0],
  },
  {
    number: '2',
    category: 'Solution Design',
    accent: 'blue',
    title: 'AI & software opportunities',
    tagline: 'We identify where AI and modern software tools can be applied to simplify your operations, reduce manual work, and unlock new efficiency.',
    description: 'Armed with a deep understanding of your operations, we map where AI and modern software create the most value. We evaluate tools honestly — large language models, automation pipelines, custom software, off-the-shelf products — and present 2 to 3 concrete options with real tradeoffs. You choose the path forward.',
    bullets: [
      'AI tool evaluation: LLMs, automation, ML pipelines',
      'Custom build vs. off-the-shelf analysis',
      'System architecture and integration design',
      '2–3 solution options with honest tradeoffs',
      'Recommended tech stack with full rationale',
    ],
    duration: null,
    outcome: 'A solution blueprint you fully understand and have approved.',
    icon: stepIcons[1],
  },
  {
    number: '3',
    category: 'Build',
    accent: 'pink',
    title: 'Core MVP',
    tagline: 'We build the core product fast. In 30 days you have a working MVP that solves the most critical problem — ready to validate with real users.',
    description: 'We run a focused 30-day sprint to build the core of the agreed solution. Weekly demos keep you in the loop and scope stays locked: no scope creep, no half-finished features. The goal is a working, deployed product that proves the concept with real data and real users by day 30.',
    bullets: [
      'Agile sprint with weekly demos and check-ins',
      'Strict scope — highest-impact feature set only',
      'Continuous feedback loop with your team',
      'Quality standards: tested, documented, deployable',
      'Staged deployment accessible to your team by day 30',
    ],
    duration: '30 days',
    outcome: 'A working MVP deployed in staging, validated by your team.',
    icon: stepIcons[2],
  },
  {
    number: '4',
    category: 'Launch',
    accent: 'pink',
    title: 'Implementation',
    tagline: 'We deploy and launch the solution directly in your environment. Full handoff, onboarding, and go-live support — in two weeks.',
    description: 'We move the solution from staging into your live production environment and stay with you through go-live. Your team is onboarded with hands-on training, the system is monitored and stabilized, and you receive complete documentation and full ownership. Two weeks after launch — it\'s entirely yours.',
    bullets: [
      'Production deployment in your infrastructure',
      'Team onboarding and hands-on training sessions',
      'Monitoring, stability checks, and rapid bug fixes',
      'Full handoff documentation and operational runbooks',
      'Dedicated post-launch support window',
    ],
    duration: '2 weeks',
    outcome: 'Live system running in your environment, team trained, full ownership transferred.',
    icon: stepIcons[3],
  },
];
---

<Layout>
  <!-- Nav -->
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-white/5 bg-navy/80 backdrop-blur-md">
    <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <div class="relative h-8 w-32">
        <img src="/CeremonyLogo-removebg.png" alt="Ceremony Labs" class="absolute top-1/2 left-0 -translate-y-1/2 h-24 w-auto" />
      </div>
      <div class="flex items-center gap-6 text-sm text-slate-400">
        <a href="#products" class="hover:text-white transition-colors hidden sm:block">Products</a>
        <a href="#process" class="hover:text-white transition-colors hidden sm:block">Process</a>
        <a href="#about" class="hover:text-white transition-colors hidden sm:block">About</a>
        <a
          href="#contact"
          class="bg-blue-brand hover:bg-blue-600 text-white px-4 py-1.5 rounded-full transition-colors font-medium text-sm"
        >
          Contact us
        </a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="relative min-h-screen flex flex-col items-center justify-center text-center px-6 pt-20 overflow-hidden">
    <div class="orb-blue"></div>
    <div class="orb-pink"></div>
    <div class="max-w-3xl mx-auto relative z-10">
      <div
        class="inline-flex items-center gap-2 bg-blue-brand/10 border border-blue-brand/20 rounded-full px-4 py-1.5 text-sm text-blue-light mb-8"
      >
        <span class="w-2 h-2 bg-blue-light rounded-full animate-pulse"></span>
        Two live · Two in development
      </div>

      <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6 leading-[1.1]">
        Think Laboratory.<br />
        <span
          class="bg-gradient-to-r from-blue-light via-blue-brand to-pink-brand bg-clip-text text-transparent"
        >
          Ship Ceremony.
        </span>
      </h1>

      <p class="text-lg md:text-xl text-slate-400 mb-10 max-w-xl mx-auto leading-relaxed">
        Ceremony Labs creates focused web applications for people who love data — delivering clarity, depth, and purpose-built experiences to anyone who demands more from the tools they use every day.
      </p>

      <a
        href="#contact"
        class="inline-block bg-gradient-to-r from-blue-brand to-blue-600 hover:opacity-90 text-white font-semibold px-8 py-3 rounded-full transition-all shadow-lg shadow-blue-brand/25"
      >
        Get in touch →
      </a>
    </div>
  </section>


  <!-- Engagement Process -->
  <section id="process" class="py-28 px-6 border-t border-white/5">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">How we work</h2>
        <p class="text-slate-400 max-w-xl mx-auto">
          A focused four-step process that takes you from idea to a live solution in under six weeks.
        </p>
      </div>

      <div class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {processSteps.map((step, i) => {
          const isBlue = step.accent === 'blue';
          const badgeGrad =
            i === 0 ? 'from-blue-brand to-blue-600 shadow-blue-brand/25' :
            i === 1 ? 'from-blue-brand to-pink-brand shadow-blue-brand/20' :
            i === 2 ? 'from-pink-brand to-pink-600 shadow-pink-brand/25' :
                      'from-pink-600 to-pink-brand shadow-pink-brand/25';
          return (
            <div
              class={`relative rounded-2xl bg-surface border p-8 flex flex-col gap-4 cursor-pointer select-none transition-all duration-200 hover:scale-[1.02] ${
                isBlue
                  ? 'border-blue-brand/20 hover:border-blue-brand/60'
                  : 'border-pink-brand/20 hover:border-pink-brand/60'
              }`}
              data-step={i}
              role="button"
              tabindex="0"
            >
              <div class="flex items-start justify-between gap-2">
                <div class="flex items-center gap-3">
                  <span class={`flex-shrink-0 w-10 h-10 rounded-full bg-gradient-to-br ${badgeGrad} flex items-center justify-center text-white font-bold text-sm shadow-lg`}>
                    {step.number}
                  </span>
                  <span class={`text-xs font-medium uppercase tracking-wider ${isBlue ? 'text-blue-light' : 'text-pink-light'}`}>
                    {step.category}
                  </span>
                </div>
                <div class="w-16 h-16 flex-shrink-0 opacity-70" aria-hidden="true" set:html={step.icon} />
              </div>
              <div class="flex-1">
                <div class="flex items-center gap-2 mb-3">
                  <h3 class="text-lg font-bold">{step.title}</h3>
                  {step.duration && (
                    <span class={`text-xs font-medium px-2.5 py-0.5 rounded-full border ${isBlue ? 'bg-blue-brand/10 text-blue-light border-blue-brand/20' : 'bg-pink-brand/10 text-pink-light border-pink-brand/20'}`}>
                      {step.duration}
                    </span>
                  )}
                </div>
                <p class="text-slate-400 text-sm leading-relaxed">{step.tagline}</p>
              </div>
              <div class={`flex items-center gap-1.5 text-xs font-medium opacity-35 ${isBlue ? 'text-blue-light' : 'text-pink-light'}`}>
                <svg class="w-3 h-3" fill="none" stroke="currentColor" viewBox="0 0 24 24" stroke-width="2">
                  <path stroke-linecap="round" stroke-linejoin="round" d="M4 8V4m0 0h4M4 4l5 5m11-1V4m0 0h-4m4 0l-5 5M4 16v4m0 0h4m-4 0l5-5m11 5l-5-5m5 5v-4m0 4h-4" />
                </svg>
                <span>Click to expand</span>
              </div>
            </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Products -->
  <section id="products" class="py-28 px-6">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">Our products</h2>
        <p class="text-slate-400 max-w-lg mx-auto">
          Each app is focused on one domain and built to be genuinely useful — no bloat, no
          upsells.
        </p>
      </div>

      <!-- Live products -->
      <div class="flex flex-col gap-6 mb-6">
        {
          liveProducts.map((p) => (
            <div
              class={`rounded-2xl bg-surface border p-8 hover:border-opacity-60 transition-colors duration-200 ${
                p.accent === 'pink'
                  ? 'border-pink-brand/30 hover:border-pink-brand/60'
                  : 'border-blue-brand/30 hover:border-blue-brand/60'
              }`}
            >
              <div class="flex flex-col lg:flex-row gap-8">
                <!-- Info -->
                <div class="flex flex-col gap-5 lg:w-2/5">
                  <div class="text-4xl">{p.icon}</div>
                  <div class="flex-1">
                    <div class="flex flex-wrap items-center gap-3 mb-2">
                      <h3 class="text-xl font-bold">{p.name}</h3>
                      <span class="inline-flex items-center gap-1.5 text-xs font-medium px-2.5 py-0.5 rounded-full border bg-green-500/10 text-green-400 border-green-500/20">
                        <span class="w-1.5 h-1.5 bg-green-400 rounded-full animate-pulse" />
                        Live
                      </span>
                    </div>
                    <p
                      class={`text-sm font-medium mb-3 ${
                        p.accent === 'pink' ? 'text-pink-light' : 'text-blue-light'
                      }`}
                    >
                      {p.tagline}
                    </p>
                    <p class="text-slate-400 text-sm leading-relaxed mb-6">{p.description}</p>
                    <a
                      href={p.url}
                      target="_blank"
                      rel="noopener noreferrer"
                      class={`inline-block hover:opacity-90 text-white font-semibold px-6 py-2.5 rounded-full transition-all text-sm ${
                        p.accent === 'pink'
                          ? 'bg-gradient-to-r from-pink-brand to-pink-600 shadow-lg shadow-pink-brand/25'
                          : 'bg-gradient-to-r from-blue-brand to-blue-600 shadow-lg shadow-blue-brand/25'
                      }`}
                    >
                      Visit {p.name} →
                    </a>
                  </div>
                </div>
                <!-- Video -->
                <div class="lg:w-3/5 w-full">
                  <div class="w-full rounded-xl overflow-hidden bg-black/30 aspect-video">
                    <iframe
                      src={`https://www.youtube.com/embed/${p.videoId}`}
                      class="w-full h-full"
                      allow="autoplay; fullscreen; encrypted-media; picture-in-picture"
                      allowfullscreen
                      frameborder="0"
                    />
                  </div>
                </div>
              </div>
            </div>
          ))
        }
      </div>

      <!-- Coming soon products -->
      <div class="grid md:grid-cols-2 gap-6">
        {
          products.map((p) => (
            <div
              class={`rounded-2xl bg-surface border p-8 flex flex-col gap-5 hover:scale-[1.02] transition-transform duration-200 ${
                p.accent === 'pink'
                  ? 'border-pink-brand/20 hover:border-pink-brand/40'
                  : 'border-blue-brand/20 hover:border-blue-brand/40'
              }`}
            >
              <div class="text-4xl">{p.icon}</div>
              <div class="flex-1">
                <div class="flex flex-wrap items-center gap-3 mb-2">
                  <h3 class="text-xl font-bold">{p.name}</h3>
                  <span
                    class={`text-xs font-medium px-2.5 py-0.5 rounded-full border ${
                      p.accent === 'pink'
                        ? 'bg-pink-brand/10 text-pink-light border-pink-brand/20'
                        : 'bg-blue-brand/10 text-blue-light border-blue-brand/20'
                    }`}
                  >
                    Coming soon
                  </span>
                </div>
                <p
                  class={`text-sm font-medium mb-3 ${
                    p.accent === 'pink' ? 'text-pink-light' : 'text-blue-light'
                  }`}
                >
                  {p.tagline}
                </p>
                <p class="text-slate-400 text-sm leading-relaxed">{p.description}</p>
              </div>
            </div>
          ))
        }
      </div>
    </div>
  </section>

  <!-- About -->
  <section id="about" class="py-28 px-6 border-t border-white/5">
    <div class="max-w-5xl mx-auto">
      <div class="text-center mb-16">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">About us</h2>
        <p class="text-slate-400 max-w-2xl mx-auto text-lg leading-relaxed">
          We're an independent software lab built by two operators who have spent their careers shipping products and running complex systems at scale. Every product we build starts from a real need — and we see it through until it actually works.
        </p>
      </div>

      <div class="grid md:grid-cols-2 gap-8">
        <!-- Adolfo -->
        <div class="rounded-2xl bg-surface border border-blue-brand/20 p-8 flex flex-col items-center text-center gap-6">
          <img
            src="/Adolfo_Ramirez.png"
            alt="Adolfo Ramirez"
            class="w-32 h-32 rounded-2xl object-cover border border-blue-brand/30"
          />
          <div>
            <h3 class="text-xl font-bold">Adolfo Ramirez</h3>
            <p class="text-blue-light text-sm font-medium mt-1">CEO & Co-founder</p>
          </div>
          <p class="text-slate-400 text-sm leading-relaxed">
            With over two decades of international leadership experience, Adolfo has built a career
            spanning operations, manufacturing, business development, and executive management.
            He brings deep expertise in P&L accountability, team building, demand planning, and
            navigating complex corporate environments across borders — the operational discipline
            and business acumen that turns bold ideas into sustainable ventures.
          </p>
        </div>

        <!-- Gaston -->
        <div class="rounded-2xl bg-surface border border-pink-brand/20 p-8 flex flex-col items-center text-center gap-6">
          <img
            src="/Gaston_Iriarte.png"
            alt="Gaston Iriarte"
            class="w-32 h-32 rounded-2xl object-cover border border-pink-brand/30"
          />
          <div>
            <h3 class="text-xl font-bold">Gaston Iriarte</h3>
            <p class="text-pink-light text-sm font-medium mt-1">CTO & Co-founder</p>
          </div>
          <p class="text-slate-400 text-sm leading-relaxed">
            A software engineer and cloud architect with over a decade of hands-on experience
            building scalable systems, Gaston specializes in cloud infrastructure, backend
