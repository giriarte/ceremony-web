            <p style="font-size:0.65rem;text-transform:uppercase;letter-spacing:0.1em;color:#475569;margin:0 0 0.5rem;">Outcome</p>
            <p style="font-size:0.875rem;color:#cbd5e1;line-height:1.65;margin:0;">${step.outcome}</p>
          </div>
        </div>
      </div>`;
  }

  // ── Nav state (arrows + dots) ───────────────────────────────────────────
  function updateNav() {
    const step    = processSteps[currentStepIdx];
    const isBlue  = step.accent === 'blue';
    const accent  = isBlue ? '#60a5fa' : '#f472b6';
    const glowClr = isBlue ? 'rgba(59,130,246,0.18)' : 'rgba(236,72,153,0.18)';
    const last    = processSteps.length - 1;

    prevBtn.style.opacity       = currentStepIdx === 0    ? '0'    : '1';
    prevBtn.style.pointerEvents = currentStepIdx === 0    ? 'none' : 'auto';
    nextBtn.style.opacity       = currentStepIdx === last ? '0'    : '1';
    nextBtn.style.pointerEvents = currentStepIdx === last ? 'none' : 'auto';

    // Store accent on buttons for hover handler
    prevBtn.dataset.accent = nextBtn.dataset.accent = accent;
    prevBtn.dataset.glow   = nextBtn.dataset.glow   = glowClr;

    // Step dots
    dotsEl.innerHTML = processSteps.map((_, i) => {
      const active = i === currentStepIdx;
      return `<span style="display:block;border-radius:9999px;transition:all 0.3s ease;width:${active ? '1.5rem' : '0.5rem'};height:0.5rem;background:${active ? accent : 'rgba(255,255,255,0.18)'};" aria-hidden="true"></span>`;
    }).join('');
  }

  // Arrow hover glow
  [prevBtn, nextBtn].forEach(btn => {
    btn.addEventListener('mouseenter', () => {
      btn.style.background   = btn.dataset.glow   || 'rgba(255,255,255,0.1)';
      btn.style.borderColor  = (btn.dataset.accent || '#60a5fa') + '80';
      btn.style.color        =  btn.dataset.accent || '#60a5fa';
      btn.style.boxShadow    = `0 0 18px ${btn.dataset.glow || 'transparent'}`;
    });
    btn.addEventListener('mouseleave', () => {
      btn.style.background  = 'rgba(255,255,255,0.06)';
      btn.style.borderColor = 'rgba(255,255,255,0.1)';
      btn.style.color       = 'white';
      btn.style.boxShadow   = 'none';
    });
  });

  // ── Step transition (slide) ─────────────────────────────────────────────
  function applyAccent(step) {
    const isBlue = step.accent === 'blue';
    card.style.borderLeft = `3px solid ${isBlue ? 'rgba(59,130,246,0.25)' : 'rgba(236,72,153,0.25)'}`;
    card.style.background = isBlue
      ? 'linear-gradient(160deg,#0d1630 70%,rgba(59,130,246,0.04) 100%)'
      : 'linear-gradient(160deg,#0d1630 70%,rgba(236,72,153,0.04) 100%)';
  }

  function transitionToStep(newIdx, direction) {
    if (isTransitioning) return;
    isTransitioning = true;

    const ease = 'cubic-bezier(0.4,0,0.2,1)';
    const dur  = '320ms';
    const outX = direction === 'next' ? '-105%' : '105%';
    const inX  = direction === 'next' ? '105%'  : '-105%';

    const current = inner.querySelector('.po-content');

    const next = document.createElement('div');
    next.className = 'po-content';
    next.style.cssText = `position:absolute;inset:0;overflow-y:auto;transform:translateX(${inX});opacity:0;`;
    next.innerHTML = buildContent(processSteps[newIdx], newIdx);
    inner.appendChild(next);

    if (current) {
      current.style.transition = `transform ${dur} ${ease},opacity ${dur} ease`;
      current.style.transform  = `translateX(${outX})`;
      current.style.opacity    = '0';
    }

    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        next.style.transition = `transform ${dur} ${ease},opacity ${dur} ease`;
        next.style.transform  = 'translateX(0)';
        next.style.opacity    = '1';
      });
    });

    currentStepIdx = newIdx;
    applyAccent(processSteps[newIdx]);
    updateNav();

    setTimeout(() => {
      if (current) current.remove();
      isTransitioning = false;
    }, 340);
  }

  // ── Open / close ────────────────────────────────────────────────────────
  function openStep(idx, cardEl) {
    const step = processSteps[idx];
    if (!step) return;

    currentStepIdx = idx;
    storedRect     = cardEl.getBoundingClientRect();

    // Build first content slide
    const wrapper = document.createElement('div');
    wrapper.className = 'po-content';
    wrapper.style.cssText = 'position:absolute;inset:0;overflow-y:auto;';
    wrapper.innerHTML = buildContent(step, idx);
    inner.innerHTML = '';
    inner.appendChild(wrapper);

    applyAccent(step);
    updateNav();

    Object.assign(card.style, {
      transition:   'none',
      top:          storedRect.top    + 'px',
      left:         storedRect.left   + 'px',
      width:        storedRect.width  + 'px',
      height:       storedRect.height + 'px',
      borderRadius: '16px',
      display:      'flex',
    });
    card.setAttribute('aria-hidden', 'false');

    backdrop.style.opacity       = '1';
    backdrop.style.pointerEvents = 'auto';
    document.body.style.overflow = 'hidden';

    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        const ease = 'cubic-bezier(0.4,0,0.2,1)';
        card.style.transition = `top .45s ${ease},left .45s ${ease},width .45s ${ease},height .45s ${ease},border-radius .45s ${ease}`;
        Object.assign(card.style, { top:'0', left:'0', width:'100vw', height:'100vh', borderRadius:'0' });
      });
    });

    contentTimer = setTimeout(() => { inner.style.opacity = '1'; }, 430);
  }

  function closeOverlay() {
    if (!storedRect) return;
    if (contentTimer) clearTimeout(contentTimer);

    inner.style.opacity = '0';

    setTimeout(() => {
      const ease = 'cubic-bezier(0.4,0,0.2,1)';
      card.style.transition = `top .4s ${ease},left .4s ${ease},width .4s ${ease},height .4s ${ease},border-radius .4s ${ease}`;
      Object.assign(card.style, {
        top: storedRect.top + 'px', left: storedRect.left + 'px',
        width: storedRect.width + 'px', height: storedRect.height + 'px',
        borderRadius: '16px',
      });
      backdrop.style.opacity       = '0';
      backdrop.style.pointerEvents = 'none';

      setTimeout(() => {
        card.style.display = 'none';
        card.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        storedRect = null;
      }, 420);
    }, 140);
  }

  // ── Event listeners ─────────────────────────────────────────────────────
  document.querySelectorAll('[data-step]').forEach(el => {
    el.addEventListener('click', () => openStep(parseInt(el.dataset.step, 10), el));
    el.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); openStep(parseInt(el.dataset.step, 10), el); }
    });
  });

  prevBtn.addEventListener('click', () => { if (currentStepIdx > 0) transitionToStep(currentStepIdx - 1, 'prev'); });
  nextBtn.addEventListener('click', () => { if (currentStepIdx < processSteps.length - 1) transitionToStep(currentStepIdx + 1, 'next'); });

  closeBtn.addEventListener('click', closeOverlay);
  backdrop.addEventListener('click', closeOverlay);
  document.addEventListener('keydown', e => {
    if (!storedRect) return;
    if (e.key === 'Escape') closeOverlay();
    if (e.key === 'ArrowLeft'  && currentStepIdx > 0)                        transitionToStep(currentStepIdx - 1, 'prev');
    if (e.key === 'ArrowRight' && currentStepIdx < processSteps.length - 1) transitionToStep(currentStepIdx + 1, 'next');
  });
</script>
