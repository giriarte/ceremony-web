    const badgeBg     = isBlue ? 'rgba(59,130,246,0.12)'  : isGreen ? 'rgba(16,185,129,0.12)'  : 'rgba(236,72,153,0.12)';
    const badgeBorder = isBlue ? 'rgba(59,130,246,0.3)'   : isGreen ? 'rgba(16,185,129,0.3)'   : 'rgba(236,72,153,0.3)';
    const dotColor    = isBlue ? '#3b82f6' : isGreen ? '#10b981' : '#ec4899';

    const items      = getActiveItems();
    const total      = items.length;
    const stepLabel  = isGreen ? `Service ${step.number} of ${total}` : `Step ${step.number} of ${total}`;
    const illusIdx   = activeCategory === 'ai' ? idx : idx + 4;
    const illus      = ILLUSTRATIONS[illusIdx] || '';

    const bulletsHtml = step.bullets.map(b =>
      `<li style="display:flex;align-items:flex-start;gap:0.875rem;">
         <span style="flex-shrink:0;margin-top:0.55rem;width:0.35rem;height:0.35rem;border-radius:50%;background:${dotColor};"></span>
         <span style="color:#cbd5e1;font-size:0.925rem;line-height:1.7;">${b}</span>
       </li>`
    ).join('');

    const durationHtml = step.duration
      ? `<div>
           <p style="font-size:0.65rem;text-transform:uppercase;letter-spacing:0.1em;color:#475569;margin:0 0 0.5rem;">Duration</p>
           <span style="font-size:0.8rem;font-weight:500;padding:0.3rem 0.9rem;border-radius:9999px;border:1px solid ${badgeBorder};background:${badgeBg};color:${accentColor};">${step.duration}</span>
         </div>`
      : '';

    return `
      <div style="position:relative;display:flex;flex-direction:column;min-height:100%;max-width:780px;margin:0 auto;padding:4rem 3.5rem 5rem;box-sizing:border-box;">
        <div aria-hidden="true" style="position:absolute;right:-0.5rem;top:50%;transform:translateY(-50%);font-size:min(38vw,28rem);font-weight:900;color:white;opacity:0.022;line-height:1;pointer-events:none;user-select:none;letter-spacing:-0.05em;">0${step.number}</div>

        <div style="display:flex;align-items:flex-start;justify-content:space-between;gap:1.5rem;flex-wrap:wrap;margin-bottom:2rem;position:relative;">
          <div style="display:flex;align-items:center;gap:0.875rem;padding-top:0.2rem;">
            <span style="flex-shrink:0;width:3rem;height:3rem;border-radius:50%;background:linear-gradient(135deg,${gradFrom},${gradTo});display:flex;align-items:center;justify-content:center;color:white;font-weight:700;font-size:1.125rem;box-shadow:0 4px 20px ${gradFrom}40;">${step.number}</span>
            <div>
              <div style="font-size:0.65rem;font-weight:600;letter-spacing:0.14em;text-transform:uppercase;color:${accentColor};">${step.category}</div>
              <div style="font-size:0.7rem;color:#475569;margin-top:2px;">${stepLabel}</div>
            </div>
          </div>
          <div class="po-illus" aria-hidden="true" style="flex-shrink:0;width:clamp(110px,22%,145px);aspect-ratio:1;">${illus}</div>
        </div>

        <h2 style="font-size:clamp(1.9rem,4.5vw,3rem);font-weight:700;line-height:1.1;margin:0 0 1.2rem;color:white;position:relative;">${step.title}</h2>
        <p style="color:#94a3b8;font-size:1.02rem;line-height:1.82;margin:0 0 2.25rem;max-width:580px;position:relative;">${step.description}</p>
        <ul style="display:flex;flex-direction:column;gap:0.875rem;margin:0 0 3rem;padding:0;list-style:none;position:relative;">${bulletsHtml}</ul>
        <div style="margin-top:auto;padding-top:1.75rem;border-top:1px solid rgba(255,255,255,0.07);display:flex;flex-wrap:wrap;align-items:flex-start;gap:2.5rem;position:relative;">
          ${durationHtml}
          <div style="flex:1;min-width:180px;">
            <p style="font-size:0.65rem;text-transform:uppercase;letter-spacing:0.1em;color:#475569;margin:0 0 0.5rem;">Outcome</p>
            <p style="font-size:0.875rem;color:#cbd5e1;line-height:1.65;margin:0;">${step.outcome}</p>
          </div>
        </div>
      </div>`;
  }

  // ── Nav state (arrows + dots) ───────────────────────────────────────────
  function updateNav() {
    const items   = getActiveItems();
    const step    = items[currentStepIdx];
    const isBlue  = step.accent === 'blue';
    const isGreen = step.accent === 'green';
    const accent  = isBlue ? '#60a5fa' : isGreen ? '#34d399' : '#f472b6';
    const glowClr = isBlue ? 'rgba(59,130,246,0.18)' : isGreen ? 'rgba(16,185,129,0.18)' : 'rgba(236,72,153,0.18)';
    const last    = items.length - 1;

    prevBtn.style.opacity       = currentStepIdx === 0    ? '0'    : '1';
    prevBtn.style.pointerEvents = currentStepIdx === 0    ? 'none' : 'auto';
    nextBtn.style.opacity       = currentStepIdx === last ? '0'    : '1';
    nextBtn.style.pointerEvents = currentStepIdx === last ? 'none' : 'auto';

    prevBtn.dataset.accent = nextBtn.dataset.accent = accent;
    prevBtn.dataset.glow   = nextBtn.dataset.glow   = glowClr;

    dotsEl.innerHTML = items.map((_, i) => {
      const active = i === currentStepIdx;
      return `<span style="display:block;border-radius:9999px;transition:all 0.3s ease;width:${active ? '1.5rem' : '0.5rem'};height:0.5rem;background:${active ? accent : 'rgba(255,255,255,0.18)'};" aria-hidden="true"></span>`;
    }).join('');
  }

  // Arrow hover glow
  [prevBtn, nextBtn].forEach(btn => {
    btn.addEventListener('mouseenter', () => {
      btn.style.background   = btn.dataset.glow   || 'rgba(255,255,255,0.1)';
      btn.style.borderColor  = (btn.dataset.accent || '#60a5fa') + '80';
      btn.style.color        =  btn.dataset.accent || '#60a5fa';
      btn.style.boxShadow    = `0 0 18px ${btn.dataset.glow || 'transparent'}`;
    });
    btn.addEventListener('mouseleave', () => {
      btn.style.background  = 'rgba(255,255,255,0.06)';
      btn.style.borderColor = 'rgba(255,255,255,0.1)';
      btn.style.color       = 'white';
      btn.style.boxShadow   = 'none';
    });
  });

  // ── Step transition (slide) ─────────────────────────────────────────────
  function applyAccent(step) {
    const isBlue  = step.accent === 'blue';
    const isGreen = step.accent === 'green';
    card.style.borderLeft = `3px solid ${isBlue ? 'rgba(59,130,246,0.25)' : isGreen ? 'rgba(16,185,129,0.25)' : 'rgba(236,72,153,0.25)'}`;
    card.style.background = isBlue
      ? 'linear-gradient(160deg,#0d1630 70%,rgba(59,130,246,0.04) 100%)'
      : isGreen
      ? 'linear-gradient(160deg,#0d1630 70%,rgba(16,185,129,0.04) 100%)'
      : 'linear-gradient(160deg,#0d1630 70%,rgba(236,72,153,0.04) 100%)';
  }

  function transitionToStep(newIdx, direction) {
    if (isTransitioning) return;
    isTransitioning = true;

    const ease = 'cubic-bezier(0.4,0,0.2,1)';
    const dur  = '320ms';
    const outX = direction === 'next' ? '-105%' : '105%';
    const inX  = direction === 'next' ? '105%'  : '-105%';

    const current = inner.querySelector('.po-content');

    const next = document.createElement('div');
    next.className = 'po-content';
    next.style.cssText = `position:absolute;inset:0;overflow-y:auto;transform:translateX(${inX});opacity:0;`;
    next.innerHTML = buildContent(getActiveItems()[newIdx], newIdx);
    inner.appendChild(next);

    if (current) {
      current.style.transition = `transform ${dur} ${ease},opacity ${dur} ease`;
      current.style.transform  = `translateX(${outX})`;
      current.style.opacity    = '0';
    }

    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        next.style.transition = `transform ${dur} ${ease},opacity ${dur} ease`;
        next.style.transform  = 'translateX(0)';
        next.style.opacity    = '1';
      });
    });

    currentStepIdx = newIdx;
    applyAccent(getActiveItems()[newIdx]);
    updateNav();

    setTimeout(() => {
      if (current) current.remove();
      isTransitioning = false;
    }, 340);
  }

  // ── Open / close ────────────────────────────────────────────────────────
  function openStep(idx, cardEl) {
    const step = getActiveItems()[idx];
    if (!step) return;

    currentStepIdx = idx;
    storedRect     = cardEl.getBoundingClientRect();

    const wrapper = document.createElement('div');
    wrapper.className = 'po-content';
    wrapper.style.cssText = 'position:absolute;inset:0;overflow-y:auto;';
    wrapper.innerHTML = buildContent(step, idx);
    inner.innerHTML = '';
    inner.appendChild(wrapper);

    applyAccent(step);
    updateNav();

    Object.assign(card.style, {
      transition:   'none',
      top:          storedRect.top    + 'px',
      left:         storedRect.left   + 'px',
      width:        storedRect.width  + 'px',
      height:       storedRect.height + 'px',
      borderRadius: '16px',
      display:      'flex',
    });
    card.setAttribute('aria-hidden', 'false');

    backdrop.style.opacity       = '1';
    backdrop.style.pointerEvents = 'auto';
    document.body.style.overflow = 'hidden';

    requestAnimationFrame(() => {
      requestAnimationFrame(() => {
        const ease = 'cubic-bezier(0.4,0,0.2,1)';
        card.style.transition = `top .45s ${ease},left .45s ${ease},width .45s ${ease},height .45s ${ease},border-radius .45s ${ease}`;
        Object.assign(card.style, { top:'0', left:'0', width:'100vw', height:'100vh', borderRadius:'0' });
      });
    });

    contentTimer = setTimeout(() => { inner.style.opacity = '1'; }, 430);
  }

  function closeOverlay() {
    if (!storedRect) return;
    if (contentTimer) clearTimeout(contentTimer);

    inner.style.opacity = '0';

    setTimeout(() => {
      const ease = 'cubic-bezier(0.4,0,0.2,1)';
      card.style.transition = `top .4s ${ease},left .4s ${ease},width .4s ${ease},height .4s ${ease},border-radius .4s ${ease}`;
      Object.assign(card.style, {
        top: storedRect.top + 'px', left: storedRect.left + 'px',
        width: storedRect.width + 'px', height: storedRect.height + 'px',
        borderRadius: '16px',
      });
      backdrop.style.opacity       = '0';
      backdrop.style.pointerEvents = 'none';

      setTimeout(() => {
        card.style.display = 'none';
        card.setAttribute('aria-hidden', 'true');
        document.body.style.overflow = '';
        storedRect = null;
      }, 420);
    }, 140);
  }

  // ── Tab switching ───────────────────────────────────────────────────────
  const tabAi  = document.getElementById('tab-ai');
  const tabWeb = document.getElementById('tab-web');
  const gridAi = document.getElementById('grid-ai');
  const gridWeb = document.getElementById('grid-web');

  function switchTab(cat) {
    activeCategory = cat;
    if (cat === 'ai') {
      tabAi.style.background  = 'linear-gradient(135deg,#3b82f6,#2563eb)';
      tabAi.style.color       = 'white';
      tabAi.style.boxShadow   = '0 2px 12px rgba(59,130,246,0.3)';
      tabWeb.style.background = '';
      tabWeb.style.color      = '#94a3b8';
      tabWeb.style.boxShadow  = '';
      gridAi.classList.remove('hidden');
      gridWeb.classList.add('hidden');
    } else {
      tabWeb.style.background = 'linear-gradient(135deg,#10b981,#059669)';
      tabWeb.style.color      = 'white';
      tabWeb.style.boxShadow  = '0 2px 12px rgba(16,185,129,0.3)';
      tabAi.style.background  = '';
      tabAi.style.color       = '#94a3b8';
      tabAi.style.boxShadow   = '';
      gridWeb.classList.remove('hidden');
      gridAi.classList.add('hidden');
    }
  }

  tabAi.addEventListener('click',  () => switchTab('ai'));
  tabWeb.addEventListener('click', () => switchTab('webdev'));

  // ── Event listeners ─────────────────────────────────────────────────────
  document.querySelectorAll('[data-step]').forEach(el => {
    el.addEventListener('click', () => {
      activeCategory = 'ai';
      openStep(parseInt(el.dataset.step, 10), el);
    });
    el.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        activeCategory = 'ai';
        openStep(parseInt(el.dataset.step, 10), el);
      }
    });
  });

  document.querySelectorAll('[data-webdev]').forEach(el => {
    el.addEventListener('click', () => {
      activeCategory = 'webdev';
      openStep(parseInt(el.dataset.webdev, 10), el);
    });
    el.addEventListener('keydown', e => {
      if (e.key === 'Enter' || e.key === ' ') {
        e.preventDefault();
        activeCategory = 'webdev';
        openStep(parseInt(el.dataset.webdev, 10), el);
      }
    });
  });

  prevBtn.addEventListener('click', () => { if (currentStepIdx > 0) transitionToStep(currentStepIdx - 1, 'prev'); });
  nextBtn.addEventListener('click', () => { if (currentStepIdx < getActiveItems().length - 1) transitionToStep(currentStepIdx + 1, 'next'); });

  closeBtn.addEventListener('click', closeOverlay);
  backdrop.addEventListener('click', closeOverlay);
  document.addEventListener('keydown', e => {
    if (!storedRect) return;
    if (e.key === 'Escape') closeOverlay();
    if (e.key === 'ArrowLeft'  && currentStepIdx > 0)                             transitionToStep(currentStepIdx - 1, 'prev');
    if (e.key === 'ArrowRight' && currentStepIdx < getActiveItems().length - 1)   transitionToStep(currentStepIdx + 1, 'next');
  });
</script>
