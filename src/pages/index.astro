        </div>

        <h2 style="font-size:clamp(1.9rem,4.5vw,3rem);font-weight:700;line-height:1.1;margin:0 0 1.2rem;color:white;position:relative;">${step.title}</h2>
        <p style="color:#94a3b8;font-size:1.02rem;line-height:1.82;margin:0 0 2.25rem;max-width:580px;position:relative;">${step.description}</p>
        <ul style="display:flex;flex-direction:column;gap:0.875rem;margin:0 0 3rem;padding:0;list-style:none;position:relative;">${bulletsHtml}</ul>
        <div style="margin-top:auto;padding-top:1.75rem;border-top:1px solid rgba(255,255,255,0.07);display:flex;flex-wrap:wrap;align-items:flex-start;gap:2.5rem;position:relative;">
