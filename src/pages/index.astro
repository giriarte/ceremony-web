---

<Layout>
  <!-- Nav -->
  <nav class="fixed top-0 left-0 right-0 z-50 border-b border-white/5 bg-navy/80 backdrop-blur-md">
    <div class="max-w-6xl mx-auto px-6 py-4 flex items-center justify-between">
      <div class="relative h-8 w-32">
        <img src="/CeremonyLogo-removebg.png" alt="Ceremony Labs" class="absolute top-1/2 left-0 -translate-y-1/2 h-24 w-auto" />
      </div>
      <div class="flex items-center gap-6 text-sm text-slate-400">
        <a href="#products" class="hover:text-white transition-colors hidden sm:block">Products</a>
        <a href="#process" class="hover:text-white transition-colors hidden sm:block">Process</a>
        <a href="#about" class="hover:text-white transition-colors hidden sm:block">About</a>
        <a
          href="#contact"
          class="bg-blue-brand hover:bg-blue-600 text-white px-4 py-1.5 rounded-full transition-colors font-medium text-sm"
        >
          Contact us
        </a>
      </div>
    </div>
  </nav>

  <!-- Hero -->
  <section class="relative min-h-screen flex flex-col items-center justify-center text-center px-6 pt-20 overflow-hidden">
    <div class="orb-blue"></div>
    <div class="orb-pink"></div>
    <div class="max-w-3xl mx-auto relative z-10">
      <div
        class="inline-flex items-center gap-2 bg-blue-brand/10 border border-blue-brand/20 rounded-full px-4 py-1.5 text-sm text-blue-light mb-8"
      >
        <span class="w-2 h-2 bg-blue-light rounded-full animate-pulse"></span>
        4 products launched — next one can be yours
      </div>

      <h1 class="text-5xl md:text-7xl font-bold tracking-tight mb-6 leading-[1.1]">
        Think Laboratory.<br />
        <span
          class="bg-gradient-to-r from-blue-light via-blue-brand to-pink-brand bg-clip-text text-transparent"
        >
          Ship Ceremony.
        </span>
      </h1>

      <p class="text-lg md:text-xl text-slate-400 mb-10 max-w-xl mx-auto leading-relaxed">
        Ceremony Labs creates focused web applications for people who love data — delivering clarity, depth, and purpose-built experiences to anyone who demands more from the tools they use every day.
      </p>

      <a
        href="#contact"
        class="inline-block bg-gradient-to-r from-blue-brand to-blue-600 hover:opacity-90 text-white font-semibold px-8 py-3 rounded-full transition-all shadow-lg shadow-blue-brand/25"
      >
        Get in touch →
      </a>
    </div>
  </section>


  <!-- Engagement Process -->
  <section id="process" class="py-28 px-6 border-t border-white/5">
    <div class="max-w-6xl mx-auto">
      <div class="text-center mb-12">
        <h2 class="text-3xl md:text-4xl font-bold mb-4">How we work</h2>
        <p class="text-slate-400 max-w-xl mx-auto">
          Two service tracks, one focused team. Select a category to explore our process and what we deliver.
        </p>
      </div>

      <!-- Category tabs -->
      <div class="flex justify-center mb-12">
        <div class="inline-flex items-center gap-1 bg-white/5 border border-white/10 rounded-full p-1">
          <button
            id="tab-ai"
            class="px-5 py-2 rounded-full text-sm font-medium transition-all duration-200"
            style="background:linear-gradient(135deg,#3b82f6,#2563eb);color:white;box-shadow:0 2px 12px rgba(59,130,246,0.3);"
          >
            AI &amp; Software
          </button>
          <button
            id="tab-web"
            class="px-5 py-2 rounded-full text-sm font-medium transition-all duration-200 text-slate-400 hover:text-white"
          >
            Web Development
          </button>
        </div>
      </div>

      <!-- AI & Software grid -->
      <div id="grid-ai" class="grid md:grid-cols-2 lg:grid-cols-4 gap-6">
        {processSteps.map((step, i) => {
          const isBlue = step.accent === 'blue';
          const badgeGrad =
            i === 0 ? 'from-blue-brand to-blue-600 shadow-blue-brand/25' :
            i === 1 ? 'from-blue-brand to-pink-brand shadow-blue-brand/20' :
            i === 2 ? 'from-pink-brand to-pink-600 shadow-pink-brand/25' :
                      'from-pink-600 to-pink-brand shadow-pink-brand/25';
          return (
            <div
              class={`relative rounded-2xl bg-surface border p-8 flex flex-col gap-4 cursor-pointer select-none transition-all duration-200 hover:scale-[1.02] ${
                isBlue
                  ? 'border-blue-brand/20 hover:border-blue-brand/60'
                  : 'border-pink-brand/20 hover:border-pink-brand/60'
              }`}
              data-step={i}
              role="button"
              tabindex="0"
            >
              <div class="flex items-start justify-between gap-2">
                <div class="flex items-center gap-3">
                  <span class={`flex-shrink-0 w-10 h-10 rounded-full bg-gradient-to-br ${badgeGrad} flex items-center justify-center text-white font-bold text-sm shadow-lg`}>
                    {step.number}
                  </span>
