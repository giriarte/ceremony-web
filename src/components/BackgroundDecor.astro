---
const tubes = [
  {
    pos: 'left:3%;top:15%',
    accent: 'blue',
    w: 32, h: 82,
    notes: [{ char: '♪', x: 6,  delay: 0   },
            { char: '♫', x: 20, delay: 1.7 }],
  },
  {
    pos: 'right:3%;top:5%',
    accent: 'pink',
    w: 40, h: 100,
    notes: [{ char: '♬', x: 4,  delay: 0   },
            { char: '♩', x: 22, delay: 1.3 },
            { char: '♪', x: 14, delay: 2.6 }],
  },
  {
    pos: 'right:5%;top:55%',
    accent: 'blue',
    w: 26, h: 66,
    notes: [{ char: '♫', x: 4,  delay: 0.9 },
            { char: '♪', x: 16, delay: 2.2 }],
  },
  {
    pos: 'left:2%;top:68%',
    accent: 'pink',
    w: 30, h: 76,
    notes: [{ char: '♩', x: 6,  delay: 0.4 },
            { char: '♬', x: 18, delay: 1.9 }],
  },
];

const flasks = [
  { pos: 'left:7%;top:40%',  accent: 'pink', w: 44, waveDelays: [0, 0.65, 1.3]  },
  { pos: 'right:4%;top:24%', accent: 'blue', w: 52, waveDelays: [0, 0.7,  1.4]  },
  { pos: 'left:5%;top:78%',  accent: 'blue', w: 36, waveDelays: [0, 0.6,  1.2]  },
];
---

<div class="fixed inset-0 pointer-events-none overflow-hidden" style="z-index:0">

  <!-- Test tubes -->
  {tubes.map((tube) => {
    const isBlue  = tube.accent === 'blue';
    const stroke  = isBlue ? 'rgba(96,165,250,0.4)'  : 'rgba(244,114,182,0.4)';
    const fill    = isBlue ? 'rgba(59,130,246,0.07)'  : 'rgba(236,72,153,0.07)';
    const liquid  = isBlue ? 'rgba(59,130,246,0.22)'  : 'rgba(236,72,153,0.22)';
    const noteClr = isBlue ? 'rgba(96,165,250,0.75)'  : 'rgba(244,114,182,0.75)';

    const w  = tube.w;
    const h  = tube.h;
    const lx = w * 0.2;
    const rx = w * 0.8;
    const curveY  = h * 0.72;
    const bottomY = h * 0.92;

    return (
      <div class="absolute" style={`${tube.pos};opacity:0.55`}>
        <div class="relative">
          {tube.notes.map((n) => (
            <span
              class="note absolute select-none font-bold"
              style={`left:${n.x}px;bottom:${h + 6}px;color:${noteClr};animation-delay:${n.delay}s;font-size:13px`}
            >
              {n.char}
            </span>
          ))}
          <svg width={w} height={h} viewBox={`0 0 ${w} ${h}`} fill="none">
            <path
              d={`M${lx},3 L${lx},${curveY} Q${lx},${bottomY} ${w/2},${bottomY} Q${rx},${bottomY} ${rx},${curveY} L${rx},3`}
              stroke={stroke}
              stroke-width="1.5"
              fill={fill}
            />
            <path
              d={`M${lx+1},${curveY - 4} L${lx+1},${curveY} Q${lx+1},${bottomY-1} ${w/2},${bottomY-1} Q${rx-1},${bottomY-1} ${rx-1},${curveY} L${rx-1},${curveY - 4} Z`}
              fill={liquid}
            />
            <line x1={lx - 5} y1="3" x2={rx + 5} y2="3" stroke={stroke} stroke-width="2" stroke-linecap="round"/>
          </svg>
        </div>
      </div>
    );
  })}

  <!-- Erlenmeyer flasks -->
  {flasks.map((flask) => {
    const isBlue  = flask.accent === 'blue';
    const stroke  = isBlue ? 'rgba(96,165,250,0.4)'  : 'rgba(244,114,182,0.4)';
    const fill    = isBlue ? 'rgba(59,130,246,0.07)'  : 'rgba(236,72,153,0.07)';
    const liquid  = isBlue ? 'rgba(59,130,246,0.22)'  : 'rgba(236,72,153,0.22)';

    const W       = flask.w;
    const Hflask  = Math.round(W * 1.75);
    const Hwaves  = Math.round(W * 0.85);
    const Htotal  = Hflask + Hwaves;

    // Flask geometry
    const neckTopY = Hwaves;
    const neckBotY = Hwaves + Hflask * 0.25;
    const bodyBotY = Hwaves + Hflask * 0.87;
    const cornerR  = W * 0.1;
    const neckL    = W * 0.33;
    const neckR    = W * 0.67;
    const bodyL    = W * 0.04;
    const bodyR    = W * 0.96;
    const cx       = W / 2;

    // Wave arc spread & height per wave
    const spreads = [W * 0.18, W * 0.32, W * 0.46];
    const heights = [Hwaves * 0.22, Hwaves * 0.48, Hwaves * 0.76];

    return (
      <div class="absolute" style={`${flask.pos};opacity:0.55`}>
        <svg width={W} height={Htotal} viewBox={`0 0 ${W} ${Htotal}`} fill="none">

          {/* Flask body */}
          <path
            d={`M${neckL},${neckTopY} L${neckL},${neckBotY} L${bodyL},${bodyBotY}
                Q${bodyL},${bodyBotY + cornerR} ${bodyL + cornerR},${bodyBotY + cornerR}
                L${bodyR - cornerR},${bodyBotY + cornerR}
                Q${bodyR},${bodyBotY + cornerR} ${bodyR},${bodyBotY}
                L${neckR},${neckBotY} L${neckR},${neckTopY}`}
            stroke={stroke}
            stroke-width="1.5"
            fill={fill}
          />

          {/* Rim */}
          <line
            x1={neckL - W * 0.09} y1={neckTopY}
            x2={neckR + W * 0.09} y2={neckTopY}
            stroke={stroke} stroke-width="2" stroke-linecap="round"
          />

          {/* Liquid */}
          <path
            d={`M${neckL + 1},${bodyBotY - Hflask * 0.28}
                L${bodyL + 1},${bodyBotY - 1}
                Q${bodyL + 1},${bodyBotY + cornerR - 1} ${bodyL + cornerR},${bodyBotY + cornerR - 1}
                L${bodyR - cornerR},${bodyBotY + cornerR - 1}
                Q${bodyR - 1},${bodyBotY + cornerR - 1} ${bodyR - 1},${bodyBotY - 1}
                L${neckR - 1},${bodyBotY - Hflask * 0.28} Z`}
            fill={liquid}
          />

          {/* Sound waves — 3 upward arcs, rippling outward */}
          {spreads.map((spread, i) => (
            <path
              class="sound-wave"
              d={`M${cx - spread},${neckTopY} Q${cx},${neckTopY - heights[i]} ${cx + spread},${neckTopY}`}
              stroke={stroke}
              stroke-width="1.5"
              fill="none"
              style={`animation-delay:${flask.waveDelays[i]}s`}
            />
          ))}

        </svg>
      </div>
    );
  })}

</div>

<style>
  .note {
    animation: float-note 3.4s ease-out infinite;
    opacity: 0;
  }

  @keyframes float-note {
    0%   { transform: translateY(0)     scale(1);   opacity: 0; }
    12%  { opacity: 0.9; }
    100% { transform: translateY(-58px) scale(0.4); opacity: 0; }
  }

  .sound-wave {
    animation: wave-ripple 2.5s ease-out infinite;
    opacity: 0;
  }

  @keyframes wave-ripple {
    0%   { opacity: 0;    }
    12%  { opacity: 0.85; }
    85%  { opacity: 0.15; }
    100% { opacity: 0;    }
  }
</style>
