---
import '../styles/global.css';
import BackgroundDecor from '../components/BackgroundDecor.astro';
interface Props {
  title?: string;
}
const { title = 'Ceremony Labs' } = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Ceremony Labs — Building focused tools for data-driven people." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;1,14..32,400&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="text-white antialiased bg-navy">
    <BackgroundDecor />
    <slot />
  </body>
</html>
