---
import '../styles/global.css';
import BackgroundDecor from '../components/BackgroundDecor.astro';
interface Props {
  title?: string;
}
const { title = 'Ceremony Labs' } = Astro.props;
---
<!doctype html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="Ceremony Labs — Building focused tools for data-driven people." />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Inter:ital,opsz,wght@0,14..32,400;0,14..32,500;0,14..32,600;0,14..32,700;1,14..32,400&display=swap" rel="stylesheet" />
    <title>{title}</title>
  </head>
  <body class="text-white antialiased bg-navy">
    <BackgroundDecor />
    <div id="lab-cursor-dot" aria-hidden="true"></div>
    <div id="lab-cursor-ring" aria-hidden="true"></div>
    <canvas id="lab-bubble-canvas" aria-hidden="true"></canvas>
    <slot />
  </body>
</html>

<style is:global>
  @media (pointer: fine) {
    * { cursor: none !important; }
  }

  #lab-cursor-dot {
    display: none;
    position: fixed;
    pointer-events: none;
    z-index: 9999;
    width: 8px;
    height: 8px;
    background: radial-gradient(circle, #60a5fa, #3b82f6);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    box-shadow: 0 0 8px #3b82f6, 0 0 18px rgba(59, 130, 246, 0.35);
    left: -200px;
    top: -200px;
  }

  #lab-cursor-ring {
    display: none;
    position: fixed;
    pointer-events: none;
    z-index: 9998;
    width: 30px;
    height: 30px;
    border: 1.5px solid rgba(96, 165, 250, 0.45);
    border-radius: 50%;
    transform: translate(-50%, -50%);
    left: -200px;
    top: -200px;
  }

  #lab-bubble-canvas {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    pointer-events: none;
    z-index: 9997;
  }

  @media (pointer: fine) {
    #lab-cursor-dot,
    #lab-cursor-ring,
    #lab-bubble-canvas {
      display: block;
    }
  }
</style>

<script>
  const dot    = document.getElementById('lab-cursor-dot')    as HTMLElement;
  const ring   = document.getElementById('lab-cursor-ring')   as HTMLElement;
  const canvas = document.getElementById('lab-bubble-canvas') as HTMLCanvasElement;
  const ctx    = canvas.getContext('2d')!;

  let mx = -200, my = -200;
  let rx = -200, ry = -200;
  let lastSpawn = 0;

  const COLORS = ['#60a5fa', '#3b82f6', '#93c5fd', '#ec4899', '#f472b6'];

  interface Bubble {
    x: number; y: number; r: number;
    vx: number; vy: number;
    alpha: number; phase: number;
    color: string; tick: number;
  }
  const bubbles: Bubble[] = [];

  function resize() {
    canvas.width  = window.innerWidth;
    canvas.height = window.innerHeight;
  }
  resize();
  window.addEventListener('resize', resize);

  document.addEventListener('mousemove', (e) => {
    mx = e.clientX;
    my = e.clientY;

    const now = Date.now();
    if (now - lastSpawn > 38 && bubbles.length < 48) {
      lastSpawn = now;
      bubbles.push({
        x:     mx + (Math.random() - 0.5) * 8,
        y:     my + (Math.random() - 0.5) * 8,
        r:     2.5 + Math.random() * 4,
        vx:    (Math.random() - 0.5) * 0.5,
        vy:    -(0.5 + Math.random() * 1),
        alpha: 0.5 + Math.random() * 0.35,
        phase: Math.random() * Math.PI * 2,
        color: COLORS[Math.floor(Math.random() * COLORS.length)],
        tick:  0,
      });
    }
  });

  // ── Audio ──────────────────────────────────────────────────────────────
  let audioCtx: AudioContext | null = null;

  function getAC(): AudioContext {
    if (!audioCtx) audioCtx = new AudioContext();
    if (audioCtx.state === 'suspended') audioCtx.resume();
    return audioCtx;
  }

  function playBubblePop() {
    try {
      const ac = getAC();
      const t  = ac.currentTime;

      const osc     = ac.createOscillator();
      const oscGain = ac.createGain();
      osc.type = 'sine';
      osc.frequency.setValueAtTime(460, t);
      osc.frequency.exponentialRampToValueAtTime(95, t + 0.08);
      oscGain.gain.setValueAtTime(0.07, t);
      oscGain.gain.exponentialRampToValueAtTime(0.001, t + 0.09);
      osc.connect(oscGain);
      oscGain.connect(ac.destination);
      osc.start(t);
      osc.stop(t + 0.10);

      const bufSize  = Math.floor(ac.sampleRate * 0.014);
      const noiseBuf = ac.createBuffer(1, bufSize, ac.sampleRate);
      const data     = noiseBuf.getChannelData(0);
      for (let i = 0; i < bufSize; i++) data[i] = Math.random() * 2 - 1;
      const noise     = ac.createBufferSource();
      noise.buffer    = noiseBuf;
      const noiseGain = ac.createGain();
      noiseGain.gain.setValueAtTime(0.025, t);
      noiseGain.gain.exponentialRampToValueAtTime(0.001, t + 0.014);
      noise.connect(noiseGain);
      noiseGain.connect(ac.destination);
      noise.start(t);
      noise.stop(t + 0.015);
    } catch (_) {}
  }

  function playDigitalConfirm() {
    try {
      const ac = getAC();
      const t  = ac.currentTime;
      const notes: [number, number, number][] = [[370, 0, 0.065], [740, 0.075, 0.105]];
      for (const [freq, delay, dur] of notes) {
        const osc  = ac.createOscillator();
        const gain = ac.createGain();
        osc.type = 'sine';
        osc.frequency.value = freq;
        gain.gain.setValueAtTime(0, t + delay);
        gain.gain.linearRampToValueAtTime(0.22, t + delay + 0.008);
        gain.gain.exponentialRampToValueAtTime(0.001, t + delay + dur);
        osc.connect(gain);
        gain.connect(ac.destination);
        osc.start(t + delay);
        osc.stop(t + delay + dur + 0.01);
      }
    } catch (_) {}
  }

  // Wire up sounds after DOM is fully ready
  document.addEventListener('DOMContentLoaded', () => {
    // Click → digital confirm on any button or anchor
    document.addEventListener('click', (e) => {
      if ((e.target as Element).closest('a, button')) playDigitalConfirm();
    });

    // Hover → soft bubble pop on cards and nav links
    document.querySelectorAll<HTMLElement>('.rounded-2xl, nav a').forEach(el => {
      el.addEventListener('mouseenter', () => playBubblePop());
    });
  });
  // ── /Audio ─────────────────────────────────────────────────────────────

  function lerp(a: number, b: number, t: number) { return a + (b - a) * t; }

  function toRgba(hex: string, alpha: number): string {
    const r = parseInt(hex.slice(1, 3), 16);
    const g = parseInt(hex.slice(3, 5), 16);
    const b = parseInt(hex.slice(5, 7), 16);
    return `rgba(${r},${g},${b},${alpha.toFixed(3)})`;
  }

  function frame() {
    dot.style.left = mx + 'px';
    dot.style.top  = my + 'px';

    rx = lerp(rx, mx, 0.14);
    ry = lerp(ry, my, 0.14);
    ring.style.left = Math.round(rx) + 'px';
    ring.style.top  = Math.round(ry) + 'px';

    ctx.clearRect(0, 0, canvas.width, canvas.height);

    for (let i = bubbles.length - 1; i >= 0; i--) {
      const b = bubbles[i];
      b.tick++;
      b.x    += b.vx * Math.sin(b.phase + b.tick * 0.06);
      b.y    += b.vy;
      b.alpha -= 0.011;
      if (b.alpha <= 0) { bubbles.splice(i, 1); continue; }

      // Bubble ring
      ctx.beginPath();
      ctx.arc(b.x, b.y, b.r, 0, Math.PI * 2);
      ctx.strokeStyle = toRgba(b.color, b.alpha);
      ctx.lineWidth   = 1.2;
      ctx.stroke();

      // Soap-bubble shimmer
      ctx.beginPath();
      ctx.arc(b.x - b.r * 0.3, b.y - b.r * 0.35, b.r * 0.28, 0, Math.PI * 2);
      ctx.fillStyle = `rgba(255,255,255,${(b.alpha * 0.35).toFixed(3)})`;
      ctx.fill();
    }

    requestAnimationFrame(frame);
  }
  frame();
</script>
